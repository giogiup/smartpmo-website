# Global security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-XSS-Protection: 0
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' static.cloudflareinsights.com unpkg.com challenges.cloudflare.com eocampaign1.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; img-src 'self' data: blob:; font-src 'self' fonts.gstatic.com; connect-src 'self' smartpmo-votes.ggpera.workers.dev api.emailoctopus.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' emailoctopus.com; object-src 'none'
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# CRITICAL: Prevent pages.dev duplicate indexing
https://smartpmo-website.pages.dev/*
  X-Robots-Tag: noindex

# Cache fingerprinted static assets (1 year, immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# JSON data feeds — 5 minute cache
/daily-cards.json
  Cache-Control: public, max-age=300

/displayed-articles.json
  Cache-Control: public, max-age=300

/live-stats.json
  Cache-Control: public, max-age=300

# HTML pages — always revalidate
/
  Cache-Control: public, max-age=0, must-revalidate

/prompts
  Cache-Control: public, max-age=0, must-revalidate

/assessment
  Cache-Control: public, max-age=0, must-revalidate

/about
  Cache-Control: public, max-age=0, must-revalidate
